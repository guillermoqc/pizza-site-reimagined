# Copy this file to .env and fill in your values.
# Never commit .env to version control.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_STORE_ID=your-store-uuid-here

# URL for the backend dashboard API (FastAPI). Use http://localhost:8000 for local dev.
# In production, set this to your deployed API URL (must be HTTPS).
VITE_DASHBOARD_API_URL=http://localhost:8000
