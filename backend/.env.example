# Supabase PostgreSQL direct connection
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use the "Transaction pooler" URL and replace [YOUR-PASSWORD] with your DB password
DATABASE_URL=postgresql+asyncpg://postgres.mcizinkxwwcxptfflpsi:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# JWT — generate a strong random string for production
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# First admin seeded automatically on startup (change before deploying)
FIRST_ADMIN_EMAIL=admin@pizza.com
FIRST_ADMIN_PASSWORD=changeme123
FIRST_ADMIN_FULL_NAME=Administrator

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
